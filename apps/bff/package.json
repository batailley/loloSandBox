{
  "name": "@lolo/bff",
  "version": "0.0.0",
  "private": true,
  "description": "Backend-for-Frontend (Hono + Node)",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "node --env-file=.env --import=tsx/esm --watch src/index.ts",
    "start": "node --env-file=.env --import=tsx/esm src/index.ts",
    "build": "tsup ./src/index.ts --outDir ./dist --format esm --minify",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@hono/zod-validator": "^0.4.1",
    "@lolo/shared": "workspace:*",
    "hono": "^4.6.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@lolo/tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
