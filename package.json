{
  "name": "lolosandbox",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo d'expérimentations (apps, BFF, libs, UI kit) — TypeScript + pnpm + Nx",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev --parallel=10",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "graph": "nx graph",
    "clean": "rm -rf node_modules **/node_modules **/dist .nx"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "nx": "^20.1.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  }
}
